        <mxCell id="6yUXOibS__ZJck44A1_B-40" value="&lt;div style=&quot;&quot;&gt;&lt;ul&gt;&lt;li&gt;&lt;span style=&quot;font-size: 17px; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;font-size: 17px; background-color: transparent;&quot;&gt;&lt;font&gt;Nota fiscal&lt;/font&gt;&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;span style=&quot;font-size: 17px; background-color: transparent;&quot;&gt;&lt;font&gt;&amp;nbsp;Streamlit é frontend&lt;/font&gt;&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;span style=&quot;font-size: 17px; background-color: transparent;&quot;&gt;&lt;font&gt;&amp;nbsp;Api Gateway envia o upload do arquivo para lambda&amp;nbsp;&lt;/font&gt;&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;span style=&quot;font-size: 17px; background-color: transparent;&quot;&gt;&lt;font&gt;&amp;nbsp;Lambda realiza captura do dados e salva um txt no bucket&lt;/font&gt;&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;span style=&quot;font-size: 17px; background-color: transparent;&quot;&gt;&lt;font&gt;&amp;nbsp;S3 Bucket armazena os txts salvos&lt;/font&gt;&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;span style=&quot;font-size: 17px; background-color: transparent;&quot;&gt;&lt;font&gt;Lambda faz imput os dados no banco de Dados&amp;nbsp;&lt;/font&gt;&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;span style=&quot;font-size: 17px; background-color: transparent;&quot;&gt;&lt;font&gt;&amp;nbsp;Dynamo salva as operacoes&amp;nbsp;&lt;/font&gt;&lt;/span&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;flipH=0;flipV=1;fillColor=light-dark(#9f9d9d, #ededed);" vertex="1" parent="6yUXOibS__ZJck44A1_B-59">
